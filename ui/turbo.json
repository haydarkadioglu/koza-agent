{
  "$schema": "https://v2-8-13.turborepo.dev/schema.json",
  "globalEnv": ["CI", "KOZA_DISABLE_SHARE"],
  "globalPassThroughEnv": ["CI", "KOZA_DISABLE_SHARE"],
  "tasks": {
    "typecheck": {},
    "build": {
      "dependsOn": [],
      "outputs": ["dist/**"]
    },
    "koza#test": {
      "dependsOn": ["^build"],
      "outputs": [],
