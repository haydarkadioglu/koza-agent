    "@koza-ai/app#test": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "@koza-ai/ui#test": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "@koza-ai/session-ui#test": {
      "dependsOn": ["^build"],
      "outputs": []
    }
  }
}
